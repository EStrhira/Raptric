# Email Backend Environment Variables

# Email Service Configuration (Choose ONE)
# Option 1: SendGrid (Recommended)
SENDGRID_API_KEY=SG.your_sendgrid_api_key_here
FROM_EMAIL=noreply@esthira.com
FROM_NAME=eSthira Electric Bikes

# Option 2: Nodemailer with SMTP (Alternative)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password

# Admin Configuration
ADMIN_EMAIL=info.esthira@gmail.com
COMPANY_NAME=eSthira Electric Bikes
WEBSITE_URL=https://esthira.com

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# Security
NODE_ENV=production
CORS_ORIGIN=https://esthira.com

# Server Configuration
PORT=3001
