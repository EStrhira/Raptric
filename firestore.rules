rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Reviews collection - read-only for public, write-only for authenticated functions
    match /reviews/{reviewId} {
      // Allow anyone to read reviews
      allow read: if true;
      
      // Only allow Cloud Functions (with admin privileges) to write
      allow write: if request.auth != null && request.auth.token.admin === true;
      
      // Allow create/update only if required fields are present
      allow create: if request.auth != null && 
        request.auth.token.admin === true &&
        request.resource.data.keys().hasAll(['authorName', 'rating', 'reviewTime']);
      
      // Allow updates only by admin
      allow update: if request.auth != null && request.auth.token.admin === true;
      
      // Delete only by admin
      allow delete: if request.auth != null && request.auth.token.admin === true;
    }
    
    // Allow read access to reviews collection list
    match /reviews/{reviewId} {
      allow list: if true;
    }
  }
}
